# ===========================
# Lumimax 环境变量样本（单镜像 / compose.stack.yml）
# 拷贝为 .env 后修改实际值
# 与仓库根目录 .env.example 保持同步；本地分层配置见 api/configs/*.env.example
# ===========================

# ---------- 必填 ----------
# PostgreSQL 连接串
DB_URL=postgresql://postgres:postgres@postgres:5432/lumimax
# JWT 签名密钥，生产环境必须替换
JWT_SECRET=please-change-me-min-32-chars-aaaaaaaaaaaaaaaa
# RabbitMQ 连接串；默认使用 RabbitMQ vhost `/`
RABBITMQ_URL=amqp://root:root@rabbitmq:5672
# Redis 连接串
REDIS_URL=redis://redis:6379

# ---------- 多租户 ----------
# 默认租户 ID
DEFAULT_TENANT_ID=tenant000000000000000

# ---------- 单镜像内 loopback gRPC（gateway 转发用） ----------
# supervisord 内各进程固定监听；一般无需改
# BASE_SERVICE_GRPC_URL=127.0.0.1:4120
# BIZ_SERVICE_GRPC_URL=127.0.0.1:4130
# IOT_SERVICE_GRPC_ENDPOINT=127.0.0.1:4140

# ---------- 对象存储（base-service 用） ----------
# STORAGE_VENDOR=aws | aliyun | minio
STORAGE_VENDOR=aws
STORAGE_REGION=us-west-2
STORAGE_BUCKET=lumimax-dev
STORAGE_PUBLIC_BASE_URL=https://lumimax-dev.s3.us-west-2.amazonaws.com
STORAGE_UPLOAD_TTL_SECONDS=900
# 凭证：开发可用 keypair；生产建议走 IAM Role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------- RabbitMQ 事件总线 ----------
RABBITMQ_EVENTS_EXCHANGE=lumimax.bus
RABBITMQ_EVENTS_EXCHANGE_TYPE=topic
# biz-service 领域 ingest 消费队列
RABBITMQ_QUEUE=lumimax.q.biz.events
# 通用 DLQ
# RABBITMQ_DLX_QUEUE=lumimax.q.dead

# IoT bridge 队列（iot-service 共用上行/下行）
IOT_RABBITMQ_QUEUE=lumimax.q.iot.stream
# IoT 专用 RabbitMQ；不填时复用 RABBITMQ_URL
# IOT_RABBITMQ_URL=amqp://root:root@rabbitmq:5672
# IOT_RABBITMQ_MESSAGE_TTL_MS=
# IOT_BRIDGE_RABBITMQ_PREFETCH=20

# ---------- IoT（gateway / biz 仅 IOT_VENDOR；传输与证书在 iot-service） ----------
# IOT_VENDOR=emqx | aws
IOT_VENDOR=emqx
# callback=HTTP/gRPC 入站；mq=下行走 RabbitMQ worker，上行由 iot-service 共享订阅 EMQX（aws=sqs）
IOT_RECEIVE_MODE=mq

# 设备离线判定（biz / iot 共用）
IOT_DEVICE_OFFLINE_TIMEOUT=120
IOT_DEVICE_OFFLINE_INTERVAL=30000

# iot-service 进程专用（supervisord 会注入 iot-service；多容器时仅挂到 iot-service）
# EMQX_BROKER_URL=mqtts://emqx:8883
# EMQX_DEVICE_ENDPOINT=mqtts://devices.example.com:8883
# EMQX_REGION=self-hosted
# EMQX_HTTP_BASE_URL=http://emqx:18083
# EMQX_AUTH_SECRET=replace-with-long-random-token
# EMQX_MQTT_USERNAME=lumimax_iot
# EMQX_MQTT_CLIENT_CERT_PEM_PATH=/app/certs/emqx/iot-service.crt
# EMQX_MQTT_CLIENT_KEY_PEM_PATH=/app/certs/emqx/iot-service.key
# EMQX_ROOT_CA_PEM_PATH=/app/certs/emqx/ca.crt
# EMQX_ROOT_CA_PEM=
# EMQX_ROOT_CA_KEY_PEM=
# IOT_REGION=us-west-2
# IOT_ACCESS_KEY_ID=
# IOT_ACCESS_KEY_SECRET=
# AWS_SQS_QUEUE_URL=
# AWS_IOT_ENDPOINT=
# AWS_IOT_POLICY_NAME=

# biz-service → iot-service gRPC（单镜像 loopback）
# IOT_SERVICE_GRPC_ENDPOINT=127.0.0.1:4140

# iot-service 只读设备元数据（单镜像 loopback，一般默认即可）
# BASE_SERVICE_GRPC_ENDPOINT=127.0.0.1:4120

# ---------- EMQX 容器端口映射（compose 宿主机暴露，非 Nest 进程变量） ----------
EMQX_MQTT_PORT=2883
EMQX_MQTTS_PORT=8883
EMQX_DASHBOARD_PORT=28083
EMQX_DASHBOARD_TLS_PORT=28084

# ---------- LLM 视觉 / 营养（biz-service diet 用） ----------
DIET_VISION_PROVIDER=openai
OPENAI_API_KEY=sk-xxxx
# DIET_NUTRITION_PROVIDER_ORDER=boohee,usda_fdc,edamam
# Food Query V4（可选）
# PROVIDER_ROUTE_CONFIG_PATH=apps/biz-service/src/diet/food-query/config/provider-routes.yaml
# FOOD_QUERY_MAX_CANDIDATES=5
# Provider 命中达到该置信度后不再拉取下一候选（默认 0.9）
# FOOD_QUERY_PROVIDER_STRONG_CONFIDENCE=0.99
# FOOD_QUERY_ENABLE_LLM_FALLBACK=false

# ---------- Compose ----------
# 对外 HTTP 端口（compose.stack.yml）
# LUMIMAX_HTTP_PORT=8080
