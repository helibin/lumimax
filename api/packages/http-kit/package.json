{
  "name": "@lumimax/http-kit",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist && mkdir -p dist && cp -R ../../dist/packages/http-kit/. dist",
    "dev": "pnpm run build",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist ../../dist/packages/http-kit"
  },
  "dependencies": {
    "@lumimax/config": "workspace:*",
    "@lumimax/contracts": "workspace:*",
    "@lumimax/logger": "workspace:*",
    "@lumimax/validation": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/swagger": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "swagger-ui-express": "catalog:"
  }
}
