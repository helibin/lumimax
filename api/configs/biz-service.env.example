# Minimal biz-service configuration
IOT_VENDOR=emqx
IOT_RECEIVE_MODE=callback
IOT_DEVICE_OFFLINE_TIMEOUT=120
IOT_DEVICE_OFFLINE_INTERVAL=30000

# IOT_QUEUE_URL=
# IOT_QUEUE_WAIT_TIME_SECONDS=
# IOT_QUEUE_VISIBILITY_TIMEOUT=
# IOT_QUEUE_BATCH_SIZE=
# IOT_QUEUE_IDLE_DELAY_MS=
# IOT_ENDPOINT=
# IOT_POLICY_NAME=
# IOT_ROOT_CA_PEM=
# IOT_ROOT_CA_KEY_PEM=
# IOT_MQTT_USERNAME=
# IOT_MQTT_PASSWORD=
# IOT_MQTT_CLIENT_CERT_PEM=
# IOT_MQTT_CLIENT_KEY_PEM=
# IOT_INTERNAL_SHARED_SECRET=replace-with-long-random-token
# EMQX HTTP callbacks can point to:
#   POST /api/internal/iot/auth
#   POST /api/internal/iot/acl
#   POST /api/internal/iot/ingest
#   POST /api/internal/iot/webhook
# Optional:
# BASE_SERVICE_GRPC_ENDPOINT=127.0.0.1:4120
