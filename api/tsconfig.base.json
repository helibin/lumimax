{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "outDir": "./dist",
    "paths": {
      "@lumimax/runtime": ["packages/runtime/src"],
      "@lumimax/runtime/*": ["packages/runtime/src/*"],
      "@lumimax/logger": ["packages/logger/src"],
      "@lumimax/logger/*": ["packages/logger/src/*"],
      "@lumimax/redis": ["packages/redis/src"],
      "@lumimax/redis/*": ["packages/redis/src/*"],
      "@lumimax/database": ["packages/database/src"],
      "@lumimax/database/*": ["packages/database/src/*"],
      "@lumimax/storage": ["packages/storage/src"],
      "@lumimax/storage/*": ["packages/storage/src/*"],
      "@lumimax/health": ["packages/health/src"],
      "@lumimax/health/*": ["packages/health/src/*"],
      "@lumimax/mq": ["packages/mq/src"],
      "@lumimax/mq/*": ["packages/mq/src/*"],
      "@lumimax/http-kit": ["packages/http-kit/src"],
      "@lumimax/http-kit/*": ["packages/http-kit/src/*"],
      "@lumimax/validation": ["packages/validation/src"],
      "@lumimax/validation/*": ["packages/validation/src/*"],
      "@lumimax/crypto-utils": ["packages/crypto-utils/src"],
      "@lumimax/crypto-utils/*": ["packages/crypto-utils/src/*"],
      "@lumimax/config": ["internal/config/src"],
      "@lumimax/config/*": ["internal/config/src/*"],
      "@lumimax/auth": ["internal/auth/src"],
      "@lumimax/auth/*": ["internal/auth/src/*"],
      "@lumimax/contracts": ["internal/contracts/src"],
      "@lumimax/contracts/*": ["internal/contracts/src/*"],
      "@lumimax/integration": ["internal/integration/src"],
      "@lumimax/integration/*": ["internal/integration/src/*"],
      "@lumimax/security": ["internal/security/src"],
      "@lumimax/security/*": ["internal/security/src/*"]
    }
  }
}
