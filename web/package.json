{
  "name": "lumimax-web-monorepo",
  "version": "5.7.0",
  "private": true,
  "keywords": [
    "monorepo",
    "turbo",
    "lumimax",
    "lumimax web",
    "vue",
    "vue admin",
    "vue3"
  ],
  "homepage": "https://github.com/lumimax/web",
  "bugs": "https://github.com/lumimax/web/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/lumimax/web.git"
  },
  "license": "MIT",
  "author": {
    "name": "lumimax",
    "url": "https://github.com/lumimax"
  },
  "type": "module",
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo build",
    "docker": "./scripts/deploy/build-and-push-images.sh",
    "build:analyze": "turbo build:analyze",
    "build:admin": "pnpm run build --filter=@lumimax/admin",
    "build:www": "pnpm run build --filter=@lumimax/www",
    "build:docker": "./scripts/deploy/build-and-push-images.sh",
    "build:ele": "pnpm run build --filter=@lumimax/web-ele",
    "build:naive": "pnpm run build --filter=@lumimax/web-naive",
    "build:tdesign": "pnpm run build --filter=@lumimax/web-tdesign",
    "changeset": "pnpm exec changeset",
    "check": "pnpm run check:circular && pnpm run check:dep && pnpm run check:type && pnpm check:cspell",
    "check:circular": "vsh check-circular",
    "check:cspell": "cspell lint \"**/*.ts\" \"**/README.md\" \".changeset/*.md\" --no-progress",
    "check:dep": "vsh check-dep",
    "check:type": "turbo run typecheck",
    "clean": "node ./scripts/clean.mjs",
    "commit": "czg",
    "dev": "turbo-run dev",
    "dev:admin": "pnpm -F @lumimax/admin run dev",
    "dev:www": "pnpm -F @lumimax/www run dev",
    "dev:antdv-next": "pnpm -F @lumimax/web-antdv-next run dev",
    "dev:ele": "pnpm -F @lumimax/web-ele run dev",
    "dev:naive": "pnpm -F @lumimax/web-naive run dev",
    "dev:tdesign": "pnpm -F @lumimax/web-tdesign run dev",
    "format": "vsh lint --format",
    "format:prettier": "prettier --write .",
    "lint": "vsh lint",
    "postinstall": "pnpm -r run stub --if-present",
    "preinstall": "npx only-allow pnpm",
    "prepare": "is-ci || pnpm exec lefthook install",
    "preview": "turbo-run preview",
    "publint": "vsh publint",
    "reinstall": "pnpm clean --del-lock && pnpm install",
    "test:unit": "vitest run --dom",
    "test:e2e": "turbo run test:e2e",
    "update:deps": "npx taze -r -w",
    "version": "pnpm exec changeset version && pnpm install --no-frozen-lockfile",
    "catalog": "pnpx codemod pnpm/catalog"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@lumimax/commitlint-config": "workspace:*",
    "@lumimax/eslint-config": "workspace:*",
    "@lumimax/stylelint-config": "workspace:*",
    "@lumimax/tailwind-config": "workspace:*",
    "@lumimax/tsconfig": "workspace:*",
    "@lumimax/turbo-run": "workspace:*",
    "@lumimax/vite-config": "workspace:*",
    "@lumimax/vsh": "workspace:*",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "cross-env": "catalog:",
    "cspell": "catalog:",
    "happy-dom": "catalog:",
    "is-ci": "catalog:",
    "lefthook": "catalog:",
    "playwright": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || ^22.18.0 || ^24.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.16.0"
}
