# Root shortcut file for single-image runtime env.
# Canonical template lives at: docker/.env.example
# Keep these two files in sync.

DB_URL=postgresql://postgres:postgres@postgres:5432/lumimax
JWT_SECRET=please-change-me-min-32-chars-aaaaaaaaaaaaaaaa
RABBITMQ_URL=amqp://root:root@rabbitmq:5672
REDIS_URL=redis://redis:6379

DEFAULT_TENANT_ID=tenant000000000000000

STORAGE_VENDOR=aws
STORAGE_REGION=us-west-2
STORAGE_BUCKET=lumimax-dev
STORAGE_PUBLIC_BASE_URL=https://lumimax-dev.s3.us-west-2.amazonaws.com
STORAGE_UPLOAD_TTL_SECONDS=900

RABBITMQ_EVENTS_EXCHANGE=app.events
RABBITMQ_EVENTS_EXCHANGE_TYPE=topic

IOT_VENDOR=emqx
EMQX_BROKER_URL=mqtts://emqx:8883

DIET_VISION_PROVIDER=openai
OPENAI_API_KEY=sk-xxxx

LUMIMAX_AUTO_MIGRATE=false
