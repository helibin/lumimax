{
  "name": "@lumimax/gateway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "node:dev": "pnpm exec cross-env NODE_ENV=development TS_NODE_PROJECT=../../tsconfig.base.json TS_NODE_PREFER_TS_EXTS=true node -r ts-node/register -r tsconfig-paths/register",
    "node:watch": "pnpm node:dev --watch-path=src --watch-path=../../packages --watch-path=../../internal",
    "dev": "pnpm dev:watch",
    "dev:no-watch": "pnpm node:dev src/main.ts",
    "dev:watch": "pnpm node:watch src/main.ts",
    "build:nest": "pnpm exec nest build -p tsconfig.build.json",
    "copy:dist": "rm -rf dist && mkdir -p dist && cp -R ../../dist/apps/gateway/. dist",
    "build": "pnpm build:nest && pnpm copy:dist",
    "start": "pnpm exec cross-env NODE_ENV=production TS_NODE_PROJECT=../../tsconfig.runtime.json node -r tsconfig-paths/register ../../dist/apps/gateway/src/main.js",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lumimax/auth": "workspace:*",
    "@lumimax/config": "workspace:*",
    "@lumimax/http-kit": "workspace:*",
    "@lumimax/integration": "workspace:*",
    "@lumimax/logger": "workspace:*",
    "@lumimax/contracts": "workspace:*",
    "@lumimax/health": "workspace:*",
    "@lumimax/redis": "workspace:*",
    "@lumimax/runtime": "workspace:*",
    "@lumimax/validation": "workspace:*",
    "@grpc/grpc-js": "catalog:",
    "@grpc/proto-loader": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/microservices": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:"
  }
}
