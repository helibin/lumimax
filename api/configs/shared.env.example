# shared 共享配置模板
# JWT 签名密钥，开发环境也建议尽快替换
JWT_SECRET=change-me-in-dev
# Redis 连接串
REDIS_URL=redis://127.0.0.1:6379/10
# PostgreSQL 连接串
DB_URL=postgresql://postgres:rd@127.0.0.1:5432/lumimax
# RabbitMQ 连接串；默认使用 RabbitMQ vhost `/`
RABBITMQ_URL=amqp://root:rd@127.0.0.1:5672
# 是否输出 SQL 日志
DB_LOGGING=false

# 对称加密密钥，部分内部数据加密场景会使用
AES_KEY=

# 云厂商凭据请写到各服务 env，勿放在 shared：
# - 对象存储 / STS → configs/base-service.env.example（STORAGE_*）
# - AWS IoT / SQS → configs/iot-service.env.example（IOT_* / AWS_* / EMQX_*）
