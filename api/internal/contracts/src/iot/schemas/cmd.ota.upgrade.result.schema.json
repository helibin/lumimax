{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumimax/schemas/iot/cmd.ota.upgrade.result.schema.json",
  "title": "cmd.ota.upgrade.result",
  "type": "object",
  "allOf": [
    { "$ref": "envelope.schema.json" },
    {
      "properties": {
        "meta": {
          "properties": {
            "event": { "const": "cmd.ota.upgrade.result" }
          }
        },
        "data": {
          "type": "object",
          "required": ["otaId", "success"],
          "additionalProperties": true,
          "properties": {
            "otaId": { "type": "string", "minLength": 1 },
            "success": { "type": "boolean" },
            "errorCode": { "type": "integer" },
            "errorMessage": { "type": "string" }
          }
        }
      }
    }
  ]
}

