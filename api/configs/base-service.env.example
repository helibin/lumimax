# Optional base-service overrides.
# Most runtime values already have defaults in code.

STORAGE_VENDOR=aws
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:4000/file
# STORAGE_READ_TTL_SECONDS=600
# STORAGE_UPLOAD_TTL_SECONDS=900

# Optional: vendor-neutral object storage auth
# STORAGE_ACCESS_KEY_ID=
# STORAGE_ACCESS_KEY_SECRET=
# STORAGE_ENDPOINT=
# STORAGE_FORCE_PATH_STYLE=true
# STORAGE_SECURE=true
#
# Optional: temp credential / STS style auth
# STORAGE_STS_ROLE_ARN=
# STORAGE_STS_EXTERNAL_ID=
# STORAGE_STS_SESSION_DURATION_SECONDS=900
# STORAGE_STS_TOKEN=
#
# Backward-compatible cloud-specific aliases are still supported:
# CLOUD_REGION=
# CLOUD_ACCESS_KEY_ID=
# CLOUD_ACCESS_KEY_SECRET=
# CLOUD_STS_ROLE_ARN=
# CLOUD_STS_EXTERNAL_ID=
# CLOUD_STS_SESSION_DURATION_SECONDS=900
# CLOUD_STS_TOKEN=