# iot-service：传输（EMQX/AWS ingress、bridge 队列、下行发布、设备证书签发）
# biz-service 经 IOT_SERVICE_GRPC_ENDPOINT 调用 ProvisionOnDeviceCreated 等

# SERVICE_NAME=iot-service
# HTTP_PORT=4040
# GRPC_PORT=4140
# BASE_SERVICE_GRPC_ENDPOINT=127.0.0.1:4120

IOT_VENDOR=emqx
IOT_RECEIVE_MODE=mq

# RabbitMQ bridge（使用 RABBITMQ_URL；EMQX OSS 主链路中仅承接下行与标准化后的业务事件）
# IOT_RABBITMQ_QUEUE=lumimax.q.iot.stream
# RABBITMQ_DLX_QUEUE=lumimax.q.dead

# ---------- EMQX ----------
EMQX_BROKER_URL=mqtts://127.0.0.1:8883
EMQX_DEVICE_ENDPOINT=mqtts://127.0.0.1:8883
EMQX_REGION=self-hosted
# Compose 同网：http://emqx:18083
# EMQX_HTTP_BASE_URL=http://127.0.0.1:18083
# gateway 与 iot-service 须一致
# EMQX_AUTH_SECRET=
# mq 模式上行共享订阅（EMQX OSS 主链路）
# EMQX_SHARED_SUBSCRIPTION_GROUP=lumimax-iot
# EMQX_SHARED_SUBSCRIPTION_TOPICS=v1/+/+/req
# iot-service 作为共享订阅 MQTT consumer 的身份建议：EMQX_MQTT_USERNAME=lumimax_iot，证书 CN 也保持为 lumimax_iot
# 设备 mTLS 签发（IOT_VENDOR=emqx 时必填 PEM 或 *_PATH）
# EMQX_ROOT_CA_PEM=
# EMQX_ROOT_CA_KEY_PEM=
# EMQX_MQTT_USERNAME=lumimax_iot
# EMQX_MQTT_PASSWORD=
# EMQX_MQTT_CLIENT_CERT_PEM_PATH=/app/certs/emqx/iot-service.crt
# EMQX_MQTT_CLIENT_KEY_PEM_PATH=/app/certs/emqx/iot-service.key
# EMQX_HTTP_TLS_INSECURE=false
# IOT_ACCESS_KEY_ID=
# IOT_ACCESS_KEY_SECRET=

# ---------- AWS IoT / SQS（IOT_VENDOR=aws） ----------
# IOT_REGION=us-west-2
# IOT_ACCESS_KEY_ID=
# IOT_ACCESS_KEY_SECRET=
# AWS_SQS_QUEUE_URL=
# AWS_IOT_ENDPOINT=
# AWS_IOT_POLICY_NAME=

# IOT_DEVICE_OFFLINE_TIMEOUT=120
# IOT_DEVICE_OFFLINE_INTERVAL=30000
