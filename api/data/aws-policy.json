{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ConnectAsAttachedThing",
      "Effect": "Allow",
      "Action": "iot:Connect",
      "Resource": "arn:aws:iot:us-west-2:941756837209:client/${iot:Connection.Thing.ThingName}"
    },
    {
      "Sid": "PublishDeviceUpstream",
      "Effect": "Allow",
      "Action": "iot:Publish",
      "Resource": "arn:aws:iot:us-west-2:941756837209:topic/v1/*/${iot:Connection.Thing.ThingName}/req"
    },
    {
      "Sid": "SubscribeCloudDownstream",
      "Effect": "Allow",
      "Action": "iot:Subscribe",
      "Resource": "arn:aws:iot:us-west-2:941756837209:topicfilter/v1/*/${iot:Connection.Thing.ThingName}/res"
    },
    {
      "Sid": "ReceiveCloudDownstream",
      "Effect": "Allow",
      "Action": "iot:Receive",
      "Resource": "arn:aws:iot:us-west-2:941756837209:topic/v1/*/${iot:Connection.Thing.ThingName}/res"
    }
  ]
}
