# Lumimax local EMQX overrides.
# This file intentionally keeps HTTP dashboard enabled by default and leaves
# TLS listeners ready to be enabled once certs are generated under
# docker/emqx/certs/.

listeners.tcp.default {
  bind = "0.0.0.0:1883"
  max_connections = 1024000
}

# Enable after server certs exist in /opt/emqx/etc/certs/.
