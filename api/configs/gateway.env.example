# gateway 可选覆盖配置
# 大多数环境可以保持为空，直接使用代码默认值
# GATEWAY_GRPC_TIMEOUT_MS=5000
# GATEWAY_GRPC_MEAL_ANALYZE_TIMEOUT_MS=20000
# GATEWAY_GRPC_RETRY_COUNT=1
# GATEWAY_GRPC_RETRY_DELAY_MS=120
# EMQX_ROOT_CA_PEM_PATH=/app/certs/emqx/ca.crt
# EMQX_ROOT_CA_KEY_PEM_PATH=/app/certs/emqx/ca.key
# EMQX_MQTT_CLIENT_CERT_PEM_PATH=/app/certs/emqx/iot-service.crt
# EMQX_MQTT_CLIENT_KEY_PEM_PATH=/app/certs/emqx/iot-service.key
