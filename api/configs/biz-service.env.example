# biz-service：业务域 + 设备领域 ingest（不配置 EMQX/AWS 传输与证书 PEM）
# 设备证书签发由 iot-service 完成；见 configs/iot-service.env.example

# SERVICE_NAME=biz-service
# HTTP_PORT=4030
# GRPC_PORT=4130
# BASE_SERVICE_GRPC_ENDPOINT=127.0.0.1:4120
IOT_SERVICE_GRPC_ENDPOINT=127.0.0.1:4140

# 与 iot-service 一致（ingest 元数据）
IOT_VENDOR=emqx
IOT_RECEIVE_MODE=mq
# RABBITMQ_QUEUE=lumimax.q.biz.events
# RABBITMQ_URL=amqp://root:root@127.0.0.1:5672
# IOT_DEVICE_OFFLINE_TIMEOUT=120
# IOT_DEVICE_OFFLINE_INTERVAL=30000

# ---------- Food Query / 饮食（可选） ----------
# LLM_VISION_PROVIDER=openai
# LLM_VISION_AK=
# THIRD_PARTY_HTTP_MAX_ATTEMPTS=2
# THIRD_PARTY_HTTP_RETRY_DELAY_MS=300
# LLM_NUTRITION_PROVIDER=openai
# LLM_NUTRITION_AK=
# BOOHEE_ENABLED=false
# BOOHEE_BASE_URL=
# BOOHEE_APP_ID=
# BOOHEE_APP_KEY=
# BOOHEE_SEARCH_PATH=/api/v1/foods/search
# BOOHEE_DETAIL_PATH=/api/v1/foods/{id}
# BOOHEE_TIMEOUT_MS=8000
# USDA_FDC_API_KEY=
# EDAMAM_APP_ID=
# EDAMAM_API_KEY=
# PROVIDER_ROUTE_CONFIG_PATH=apps/biz-service/src/diet/food-query/config/provider-routes.yaml
# FOOD_QUERY_MAX_CANDIDATES=5
# Provider 命中达到该置信度后不再拉取下一候选（0.5–0.99，默认 0.99）
# FOOD_QUERY_PROVIDER_STRONG_CONFIDENCE=0.9
# FOOD_QUERY_ENABLE_LLM_FALLBACK=false
# FOOD_QUERY_ENABLE_NUTRITION_LABEL_OCR=true
# FOOD_QUERY_DEBUG_ENABLED=false

# ---------- Speech / 语音转写（可选） ----------
# SPEECH_RECOGNITION_ENABLED=true
# SPEECH_ROUTE_CONFIG_PATH=apps/biz-service/src/speech/config/speech-provider-routes.yaml
# 国内 MVP
# TENCENT_SPEECH_SECRET_ID=
# TENCENT_SPEECH_SECRET_KEY=
# TENCENT_SPEECH_REGION=ap-guangzhou
# TENCENT_SPEECH_ENGINE=16k_zh
# 海外 MVP（可复用 LLM_VISION_AK）
# SPEECH_OPENAI_AK=
# SPEECH_OPENAI_MODEL=gpt-4o-mini-transcribe
# SPEECH_OPENAI_BASE_URL=
# SPEECH_OPENAI_TIMEOUT_MS=30000
