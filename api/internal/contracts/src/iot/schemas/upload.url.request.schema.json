{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumimax/schemas/iot/upload.url.request.schema.json",
  "title": "upload.url.request",
  "type": "object",
  "allOf": [
    { "$ref": "envelope.schema.json" },
    {
      "properties": {
        "meta": {
          "properties": {
            "event": { "const": "upload.url.request" }
          }
        },
        "data": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "purpose": { "type": "string" },
            "fileType": { "type": "string" },
            "maxBytes": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  ]
}
